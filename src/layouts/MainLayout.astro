---
import Header from "../components/partials/Header.astro";
import Footer from "../components/partials/Footer.astro";

import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import customSlideAnimation from "../scripts/customSlideAnimation";

const { canonical, siteUrl, title, lang } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    {canonical && <link rel="canonical" href={`${siteUrl}${canonical}`} />}
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      const applyTheme = () => {
        const theme = localStorage.getItem('theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
        document.documentElement.dataset.theme = theme;
      };
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <script>
      import { themeStore, isSideNavOpen } from '../store.js';
      
      const syncStore = () => {
        const theme = document.documentElement.dataset.theme || 'light';
        themeStore.set(theme);
        isSideNavOpen.set(false);
      };

      syncStore();
      document.addEventListener('astro:after-swap', syncStore);
    </script>
  </head>
  <body>
    <Header />
    <main 
      transition:name="main-content" 
      transition:animate={customSlideAnimation}>
      <slot />
    </main>
    <Footer />
		<script src="../scripts/navigation.js"></script>
  </body>
</html>
